# =============================================================================
# Example environment variables — safe to commit. Copy to `.env` and fill in.
# =============================================================================

# Public URL of the site (campaign share links, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase Postgres (Prisma)
# -----------------------------------------------------------------------------
# In Supabase: Project Settings → Database → Connection string
#
# 1) DATABASE_URL — use the **pooling** URI for the running app (Transaction mode,
#    port 6543). Include `?pgbouncer=true` when shown in the Supabase UI.
#    Example shape (replace with your project values):
#    postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# 2) DIRECT_URL — **direct** Postgres for `prisma migrate` (session / port 5432),
#    or the "Direct connection" / non-pooled URI from Supabase.
#    If you use the same host as the pooler, direct is often port 5432 vs 6543.
#
# @see https://supabase.com/docs/guides/database/prisma
# -----------------------------------------------------------------------------
DATABASE_URL=
DIRECT_URL=

# -----------------------------------------------------------------------------
# Supabase Auth (JS client)
# -----------------------------------------------------------------------------
# In Supabase: Project Settings → API
# NEXT_PUBLIC_SUPABASE_URL  — "Project URL"
# NEXT_PUBLIC_SUPABASE_ANON_KEY — "anon public" key
# SUPABASE_SERVICE_ROLE_KEY — "service_role secret" key (never expose to browser)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth / Auth.js v5 — required in production
# openssl rand -base64 32
AUTH_SECRET=

# Canonical URL of this deployment (no trailing slash)
AUTH_URL=http://localhost:3000

# Comma-separated emails allowed for Super Admin login (demo mode without temp password)
ADMIN_EMAILS=you@yourdomain.com

# Optional: one email/password that must match to sign in; can use any "Account type" on /login.
# Use strong secrets; quote the password if it contains $ or spaces. Remove for production.
# TEMP_SUPER_ADMIN_EMAIL=
# TEMP_SUPER_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# PayPal / Twilio (server-only)
# -----------------------------------------------------------------------------
# Coolify/VPS env vars are preferred for production secrets. The Super Admin
# database settings page can remain as a fallback, but these env vars override it.
# Do not put secrets in NEXT_PUBLIC_*.
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Optional split credentials if sandbox and live apps should both be configured.
# If set, these override PAYPAL_CLIENT_ID / PAYPAL_CLIENT_SECRET for that mode.
# PAYPAL_SANDBOX_CLIENT_ID=
# PAYPAL_SANDBOX_CLIENT_SECRET=
# PAYPAL_LIVE_CLIENT_ID=
# PAYPAL_LIVE_CLIENT_SECRET=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# Unauthenticated UI previews: /dashboard/admin-preview, /dashboard/parent-preview, etc.
# - `npm run dev`: enabled by default.
# - Vercel Preview deployments: enabled by default (VERCEL_ENV=preview).
# - `npm run start` or Vercel Production: set to true to enable, or leave unset for off.
# ADMIN_UI_PREVIEW=true
