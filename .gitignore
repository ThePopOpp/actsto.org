# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# MCP / tool scratch JSON payloads (not part of the app)
/local/mcp-artifacts/

# Prisma / local SQLite — never commit dev databases or WAL files
/prisma/*.db
/prisma/*.db-journal
/prisma/*.db-wal
/prisma/*.db-shm

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment and secrets — never commit real credentials
.env
.env.*
!.env.example

# Cursor — local MCP URLs may include project refs; keep out of the repo
.cursor/

# Editor / agent tooling (local)
.agents/
.claude/
skills-lock.json

# Supabase CLI cache
supabase/.temp/

# Supabase migration scratch output (SQL files stay tracked)
supabase/migrations/*_out.txt
supabase/migrations/*.json.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma
