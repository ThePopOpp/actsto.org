# =============================================================================
# Example environment variables â€” safe to commit. Copy to `.env` and fill in.
# =============================================================================

# Public URL of the site (campaign share links, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase Postgres (Prisma)
# -----------------------------------------------------------------------------
# In Supabase: Project Settings â†’ Database â†’ Connection string
#
# 1) DATABASE_URL â€” use the **pooling** URI for the running app (Transaction mode,
#    port 6543). Include `?pgbouncer=true` when shown in the Supabase UI.
#    Example shape (replace with your project values):
#    postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# 2) DIRECT_URL â€” **direct** Postgres for `prisma migrate` (session / port 5432),
#    or the "Direct connection" / non-pooled URI from Supabase.
#    If you use the same host as the pooler, direct is often port 5432 vs 6543.
#
# @see https://supabase.com/docs/guides/database/prisma
# -----------------------------------------------------------------------------
DATABASE_URL=
DIRECT_URL=

# NextAuth / Auth.js v5 â€” required in production
# openssl rand -base64 32
AUTH_SECRET=

# Canonical URL of this deployment (no trailing slash)
AUTH_URL=http://localhost:3000

# Comma-separated emails allowed for Super Admin login (demo mode without temp password)
ADMIN_EMAILS=you@yourdomain.com

# Optional: one email/password that must match to sign in; can use any "Account type" on /login.
# Use strong secrets; quote the password if it contains $ or spaces. Remove for production.
# TEMP_SUPER_ADMIN_EMAIL=
# TEMP_SUPER_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# PayPal / Twilio (Super Admin)
# -----------------------------------------------------------------------------
# Sandbox, live, and SMS credentials are edited in the Super Admin dashboard and
# stored in Postgres (`AdminIntegrationSettings`). Server code can read them via
# `getPaypalSettingsForServer` / `getTwilioSettingsForServer` in
# `lib/admin/integration-settings-server.ts`. Do not put secrets in NEXT_PUBLIC_*.

# Unauthenticated UI previews: /dashboard/admin-preview, /dashboard/parent-preview, etc.
# - `npm run dev`: enabled by default.
# - Vercel Preview deployments: enabled by default (VERCEL_ENV=preview).
# - `npm run start` or Vercel Production: set to true to enable, or leave unset for off.
# ADMIN_UI_PREVIEW=true
