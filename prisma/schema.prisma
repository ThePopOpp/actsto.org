/// Billing document against a business donor's Pledge — presentation/lifecycle layer on top of Pledge
model Invoice {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pledgeId       String    @map("pledge_id") @db.Uuid
  donationId     String?   @map("donation_id") @db.Uuid
  invoiceNumber  String    @unique @map("invoice_number")
  issuedDate     DateTime  @map("issued_date") @db.Date
  dueDate        DateTime  @map("due_date") @db.Date
  /// draft | sent | paid | overdue | void
  status         String    @default("draft")
  lineItems      Json      @default("[]") @map("line_items")
  subtotal       Decimal   @db.Decimal(14, 2)
  taxRatePercent Decimal   @default(0) @map("tax_rate_percent") @db.Decimal(5, 2)
  taxAmount      Decimal   @default(0) @map("tax_amount") @db.Decimal(14, 2)
  total          Decimal   @db.Decimal(14, 2)
