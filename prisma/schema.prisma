generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  super_admin
  parent
  student
  donor_individual
  donor_business
}

enum AccountStatus {
  active
  invited
  suspended
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      UserRole
  /// JSON array of portal roles (parent, student, donor_*) this email may access; defaults from `role` when null.
  roles     Json?
  accountStatus AccountStatus @default(active)
  lastLoginAt   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[] @relation("AuditActor")
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  actorId     String?
  actorEmail  String?
  targetId    String?
  targetEmail String?
  metadata    String?
  ip          String?
  createdAt   DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
}

/// Super-admin–edited legal HTML shown on public /legal/* when a row exists.
model LegalDocument {
  id        String   @id @default(cuid())
  slug      String   @unique
  bodyHtml  String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

/// Single-row store for Super Admin campaign directory (full campaign JSON + moderation meta).
model AdminCampaignDirectory {
  id        String   @id
  rows      Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

/// Super-admin–edited integration payloads (PayPal, Twilio). Keys: `paypal`, `twilio`.
model AdminIntegrationSettings {
  key       String   @id
  payload   Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
