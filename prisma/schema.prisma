generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Existing enums — custom auth system (Phase 2: migrate to Supabase Auth)
// ============================================================

enum UserRole {
  super_admin
  parent
  student
  donor_individual
  donor_business
}

enum AccountStatus {
  active
  invited
  suspended
}

// ============================================================
// Custom auth tables (current session system — replaced in Phase 2)
// ============================================================

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  password      String
  name          String?
  role          UserRole
  /// JSON array of portal roles this email may access
  roles         Json?
  accountStatus AccountStatus @default(active) @map("account_status")
  lastLoginAt   DateTime?     @map("last_login_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  auditLogs AuditLog[] @relation("AuditActor")

  @@map("admin_users")
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  actorId     String?  @map("actor_id")
  actorEmail  String?  @map("actor_email")
  targetId    String?  @map("target_id")
  targetEmail String?  @map("target_email")
  metadata    String?
  ip          String?
  createdAt   DateTime @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// ============================================================
// Admin-managed content
// ============================================================

/// Super-admin–edited legal HTML shown on public /legal/* pages
model LegalDocument {
  id        String   @id @default(cuid())
  slug      String   @unique
  bodyHtml  String   @map("body_html")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("legal_documents")
}

/// Single-row campaign directory managed by Super Admin
model AdminCampaignDirectory {
  id        String   @id
  rows      Json
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admin_campaign_directory")
}

/// Integration settings (PayPal, Twilio). Keys: `paypal`, `twilio`
model AdminIntegrationSettings {
  key       String   @id
  payload   Json
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admin_integration_settings")
}

/// Public-site CTA blocks managed by Super Admin Site Content
model SiteCtaBlock {
  key            String   @id
  placement      String
  path           String?
  heading        String
  subheading     String?
  body           String?
  primaryLabel   String   @map("primary_label")
  primaryUrl     String   @map("primary_url")
  primaryVariant String   @default("default") @map("primary_variant")
  showSecondary  Boolean  @default(true) @map("show_secondary")
  secondaryLabel String?  @map("secondary_label")
  secondaryUrl   String?  @map("secondary_url")
  imageUrl       String?  @map("image_url")
  imageAlt       String?  @map("image_alt")
  bgColor        String?  @map("bg_color")
  bgColorEnd     String?  @map("bg_color_end")
  useGradient    Boolean  @default(false) @map("use_gradient")
  textColor      String?  @map("text_color")
  padding        String   @default("default")
  visible        Boolean  @default(true)
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("site_cta_blocks")
}

/// Site-wide content settings managed by Super Admin Site Content
model SiteContentSettings {
  key       String   @id
  payload   Json
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("site_content_settings")
}

// ============================================================
// Supabase Auth profile layer
// NOTE: Profile.id = auth.users.id (UUID). No Prisma relation
// to User because User uses a separate custom table with CUID.
// In Phase 2 (Supabase Auth migration), User will be removed
// and Profile will become the single source of identity.
// ============================================================

/// Main user profile — one row per auth.users entry
model Profile {
  id                 String   @id @db.Uuid
  email              String
  fullName           String?  @map("full_name")
  firstName          String?  @map("first_name")
  middleName         String?  @map("middle_name")
  lastName           String?  @map("last_name")
  displayName        String?  @map("display_name")
  avatarUrl          String?  @map("avatar_url")
  phone              String?
  phoneNormalized    String?  @map("phone_normalized")
  primaryAccountType String?  @map("primary_account_type")
  activeAccountType  String?  @map("active_account_type")
  status             String   @default("active")
  isAdmin            Boolean  @default(false) @map("is_admin")
  isSuperAdmin       Boolean  @default(false) @map("is_super_admin")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  userRoles              UserRoleRecord[]
  accountSetupProgress   AccountSetupProgress[]
  parentGuardianProfile  ParentGuardianProfile?
  individualDonorProfile IndividualDonorProfile?
  businessDonorProfile   BusinessDonorProfile?

  @@map("profiles")
}

// ============================================================
// Hybrid User role tables
// ============================================================

/// Extended role model — one row per user per role
model UserRoleRecord {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  role              String
  status            String   @default("active")
  completionPercent Int      @default(0) @map("completion_percent")
  isComplete        Boolean  @default(false) @map("is_complete")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

/// Per-role profile completion tracking for dashboard progress meters
model AccountSetupProgress {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  role              String
  requiredFields    Json      @default("[]") @map("required_fields")
  completedFields   Json      @default("[]") @map("completed_fields")
  missingFields     Json      @default("[]") @map("missing_fields")
  completionPercent Int       @default(0) @map("completion_percent")
  lastCheckedAt     DateTime? @map("last_checked_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("account_setup_progress")
}

// ============================================================
// Role-specific profile tables
// ============================================================

model ParentGuardianProfile {
  id                              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                          String   @unique @map("user_id") @db.Uuid
  relationshipToStudent           String?  @map("relationship_to_student")
  addressLine1                    String?  @map("address_line_1")
  addressLine2                    String?  @map("address_line_2")
  city                            String?
  state                           String?
  zip                             String?
  emergencyContactName            String?  @map("emergency_contact_name")
  emergencyContactPhone           String?  @map("emergency_contact_phone")
  emergencyContactPhoneNormalized String?  @map("emergency_contact_phone_normalized")
  profileStatus                   String   @default("incomplete") @map("profile_status")
  createdAt                       DateTime @default(now()) @map("created_at")
  updatedAt                       DateTime @updatedAt @map("updated_at")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("parent_guardian_profiles")
}

model IndividualDonorProfile {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  filingStatus   String?  @map("filing_status")
  azResident     Boolean? @map("az_resident")
  defaultTaxYear Int?     @map("default_tax_year")
  annualLimit    Decimal? @map("annual_limit") @db.Decimal(14, 2)
  profileStatus  String   @default("incomplete") @map("profile_status")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("individual_donor_profiles")
}

model BusinessDonorProfile {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                  String   @unique @map("user_id") @db.Uuid
  businessName            String?  @map("business_name")
  businessTitle           String?  @map("business_title")
  /// EIN — restrict access to owner + Super Admin only; never expose publicly
  ein                     String?
  businessEmail           String?  @map("business_email")
  businessPhone           String?  @map("business_phone")
  businessPhoneNormalized String?  @map("business_phone_normalized")
  businessType            String?  @map("business_type")
  addressLine1            String?  @map("address_line_1")
  addressLine2            String?  @map("address_line_2")
  city                    String?
  state                   String?
  zip                     String?
  profileStatus           String   @default("incomplete") @map("profile_status")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("business_donor_profiles")
}

// ============================================================
// Schools
// ============================================================

model School {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  slug            String   @unique
  schoolType      String?  @map("school_type")
  description     String?
  logoUrl         String?  @map("logo_url")
  website         String?
  phone           String?
  phoneNormalized String?  @map("phone_normalized")
  email           String?
  addressLine1    String?  @map("address_line1")
  addressLine2    String?  @map("address_line2")
  city            String?
  state           String?
  zip             String?
  county          String?
  isPartner       Boolean  @default(false) @map("is_partner")
  status          String   @default("active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  students             Student[]
  campaigns            Campaign[]
  schoolAdmins         SchoolAdmin[]
  scholarshipApps      ScholarshipApplication[]
  scholarshipAwards    ScholarshipAward[]
  scholarshipPayments  ScholarshipPayment[]
  donationAllocations  DonationAllocation[]
  donorRecommendations DonorRecommendation[]

  @@map("schools")
}

model SchoolAdmin {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String   @map("school_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @default("viewer")
  createdAt DateTime @default(now()) @map("created_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, userId])
  @@map("school_admins")
}

// ============================================================
// Students
// ============================================================

model Student {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// auth.users UUID of the parent who created this student record
  parentUserId            String    @map("parent_user_id") @db.Uuid
  /// auth.users UUID for a 16+ self-managed student account
  studentUserId           String?   @unique @map("student_user_id") @db.Uuid
  studentInviteEmail      String?   @map("student_invite_email")
  studentInviteToken      String?   @unique @map("student_invite_token")
  studentInviteExpiresAt  DateTime? @map("student_invite_expires_at")
  studentInviteAcceptedAt DateTime? @map("student_invite_accepted_at")
  schoolId                String?   @map("school_id") @db.Uuid
  firstName               String    @map("first_name")
  lastName                String?   @map("last_name")
  nickname                String?
  grade                   String?
  birthDate               DateTime? @map("birth_date") @db.Date
  ageVerified             Boolean   @default(false) @map("age_verified")
  profilePhotoUrl         String?   @map("profile_photo_url")
  phone                   String?
  phoneNormalized         String?   @map("phone_normalized")
  bio                     String?
  createdBy               String?   @map("created_by") @db.Uuid
  status                  String    @default("pending")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  school               School?                  @relation(fields: [schoolId], references: [id])
  guardians            StudentGuardian[]
  campaignStudents     CampaignStudent[]
  scholarshipApps      ScholarshipApplication[]
  scholarshipAwards    ScholarshipAward[]
  donationAllocations  DonationAllocation[]
  donorRecommendations DonorRecommendation[]

  @@map("students")
}

model StudentGuardian {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId        String   @map("student_id") @db.Uuid
  guardianUserId   String   @map("guardian_user_id") @db.Uuid
  relationship     String?
  isPrimary        Boolean  @default(false) @map("is_primary")
  permissionStatus String   @default("pending") @map("permission_status")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, guardianUserId])
  @@map("student_guardians")
}

// ============================================================
// Campaigns
// ============================================================

model CampaignType {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  campaigns Campaign[]

  @@map("campaign_types")
}

model Campaign {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// auth.users UUID of campaign creator
  createdByUserId          String    @map("created_by_user_id") @db.Uuid
  schoolId                 String?   @map("school_id") @db.Uuid
  campaignTypeId           String?   @map("campaign_type_id") @db.Uuid
  title                    String
  slug                     String    @unique
  tagline                  String?
  shortExcerpt             String?   @map("short_excerpt")
  story                    String?
  campaignType             String?   @map("campaign_type")
  /// status: draft | pending_review | active | paused | completed | rejected | archived
  status                   String    @default("draft")
  startsAt                 DateTime? @map("starts_at")
  endsAt                   DateTime? @map("ends_at")
  goalAmount               Decimal   @default(0) @map("goal_amount") @db.Decimal(14, 2)
  raisedAmount             Decimal   @default(0) @map("raised_amount") @db.Decimal(14, 2)
  donorCount               Int       @default(0) @map("donor_count")
  featuredImageUrl         String?   @map("featured_image_url")
  qrCodeUrl                String?   @map("qr_code_url")
  city                     String?
  state                    String?
  isFeatured               Boolean   @default(false) @map("is_featured")
  isPublic                 Boolean   @default(true) @map("is_public")
  completionPercent        Int       @default(0) @map("completion_percent")
  missingFields            Json      @default("[]") @map("missing_fields")
  lastCompletionReminderAt DateTime? @map("last_completion_reminder_at")
  submittedAt              DateTime? @map("submitted_at")
  approvedBy               String?   @map("approved_by") @db.Uuid
  approvedAt               DateTime? @map("approved_at")
  rejectedBy               String?   @map("rejected_by") @db.Uuid
  rejectedAt               DateTime? @map("rejected_at")
  rejectionReason          String?   @map("rejection_reason")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  school               School?               @relation(fields: [schoolId], references: [id])
  campaignTypeRelation CampaignType?         @relation(fields: [campaignTypeId], references: [id])
  campaignStudents     CampaignStudent[]
  campaignMedia        CampaignMedia[]
  givingLevels         GivingLevel[]
  campaignUpdates      CampaignUpdate[]
  campaignFaqs         CampaignFaq[]
  campaignBackers      CampaignBacker[]
  campaignComments     CampaignComment[]
  donations            Donation[]
  donationAllocations  DonationAllocation[]
  scholarshipAwards    ScholarshipAward[]
  donorRecommendations DonorRecommendation[]
  approvalQueue        ApprovalQueue[]

  @@map("campaigns")
}

model CampaignStudent {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId      String   @map("campaign_id") @db.Uuid
  studentId       String   @map("student_id") @db.Uuid
  individualGoal  Decimal  @default(0) @map("individual_goal") @db.Decimal(14, 2)
  amountAllocated Decimal  @default(0) @map("amount_allocated") @db.Decimal(14, 2)
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([campaignId, studentId])
  @@map("campaign_students")
}

model CampaignMedia {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId  String   @map("campaign_id") @db.Uuid
  /// featured_image | gallery_image | video | document
  mediaType   String   @default("gallery_image") @map("media_type")
  fileUrl     String?  @map("file_url")
  storagePath String?  @map("storage_path")
  altText     String?  @map("alt_text")
  caption     String?
  sortOrder   Int      @default(0) @map("sort_order")
  uploadedBy  String?  @map("uploaded_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_media")
}

model GivingLevel {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId     String   @map("campaign_id") @db.Uuid
  name           String
  title          String?
  minAmount      Decimal  @map("min_amount") @db.Decimal(14, 2)
  amount         Decimal? @db.Decimal(14, 2)
  description    String?
  spotsAvailable Int?     @map("spots_available")
  spotsClaimed   Int      @default(0) @map("spots_claimed")
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  campaign        Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignBackers CampaignBacker[]

  @@map("giving_levels")
}

model CampaignUpdate {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId   String    @map("campaign_id") @db.Uuid
  authorUserId String?   @map("author_user_id") @db.Uuid
  title        String
  body         String?
  status       String    @default("draft")
  publishedAt  DateTime? @map("published_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_updates")
}

model CampaignFaq {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String   @map("campaign_id") @db.Uuid
  question   String
  answer     String
  sortOrder  Int      @default(0) @map("sort_order")
  isPublic   Boolean  @default(true) @map("is_public")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_faqs")
}

model CampaignBacker {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId    String   @map("campaign_id") @db.Uuid
  donationId    String?  @map("donation_id") @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  displayName   String?  @map("display_name")
  avatarUrl     String?  @map("avatar_url")
  amount        Decimal? @db.Decimal(14, 2)
  message       String?
  isAnonymous   Boolean  @default(false) @map("is_anonymous")
  showAmount    Boolean  @default(false) @map("show_amount")
  showMessage   Boolean  @default(true) @map("show_message")
  backerType    String?  @map("backer_type")
  givingLevelId String?  @map("giving_level_id") @db.Uuid
  /// pending_review | visible | hidden | removed
  status        String   @default("pending_review")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  campaign    Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donation    Donation?    @relation(fields: [donationId], references: [id])
  givingLevel GivingLevel? @relation(fields: [givingLevelId], references: [id])

  @@map("campaign_backers")
}

model SavedCampaign {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  campaignSlug String   @map("campaign_slug")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([userId, campaignSlug])
  @@index([campaignSlug])
  @@map("saved_campaigns")
}

model CampaignComment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId      String    @map("campaign_id") @db.Uuid
  userId          String?   @map("user_id") @db.Uuid
  parentCommentId String?   @map("parent_comment_id") @db.Uuid
  authorName      String?   @map("author_name")
  authorEmail     String?   @map("author_email")
  commentBody     String    @map("comment_body")
  commentType     String    @default("encouragement") @map("comment_type")
  /// pending | approved | rejected | removed
  status          String    @default("pending")
  isPinned        Boolean   @default(false) @map("is_pinned")
  isPrivate       Boolean   @default(false) @map("is_private")
  moderatedBy     String?   @map("moderated_by") @db.Uuid
  moderatedAt     DateTime? @map("moderated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  campaign      Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  parentComment CampaignComment?  @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies       CampaignComment[] @relation("CommentReplies")

  @@map("campaign_comments")
}

// ============================================================
// Pledges (existing — keep model in sync)
// ============================================================

model Pledge {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  campaignId String   @map("campaign_id") @db.Uuid
  amount     Decimal  @db.Decimal(14, 2)
  currency   String   @default("USD")
  /// pending | confirmed | cancelled | fulfilled
  status     String   @default("pending")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  donations Donation[]
  invoices  Invoice[]

  @@map("pledges")
}

// ============================================================
// Donations and payment tables
// ============================================================

model Donation {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// auth.users UUID — null for anonymous donations
  userId                   String?  @map("user_id") @db.Uuid
  campaignId               String?  @map("campaign_id") @db.Uuid
  pledgeId                 String?  @map("pledge_id") @db.Uuid
  amount                   Decimal  @db.Decimal(14, 2)
  tipAmount                Decimal  @default(0) @map("tip_amount") @db.Decimal(14, 2)
  processingFeeAmount      Decimal  @default(0) @map("processing_fee_amount") @db.Decimal(14, 2)
  totalAmount              Decimal? @map("total_amount") @db.Decimal(14, 2)
  currency                 String   @default("USD")
  /// quick | tax_credit | business | general | campaign | manual_check
  donationType             String   @default("quick") @map("donation_type")
  /// pending | paid | failed | cancelled | refunded | partially_refunded
  status                   String   @default("pending")
  paymentProvider          String   @default("paypal") @map("payment_provider")
  paymentProviderOrderId   String?  @map("payment_provider_order_id")
  paymentProviderCaptureId String?  @map("payment_provider_capture_id")
  /// Legacy field — use paymentProviderOrderId going forward
  externalPaymentId        String?  @map("external_payment_id")
  anonymous                Boolean  @default(false)
  donorMessage             String?  @map("donor_message")
  taxYear                  Int?     @map("tax_year")
  metadata                 Json     @default("{}")
